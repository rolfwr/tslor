{
  "name": "tslor",
  "version": "0.1.0",
  "description": "TypeScript large-scale organized refactoring tool",
  "type": "module",
  "bin": {
    "tslor": "dist/tslor.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -b",
    "bundle": "tsc -p tsconfig.build.json",
    "prepare": "npm run bundle",
    "check": "tsc -b && vitest run",
    "test": "vitest run",
    "outline": "tsx src/outline.ts",
    "outline:silent": "tsx src/outline.ts"
  },
  "dependencies": {
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "diff": "^8.0.2",
    "ts-morph": "^25.0.0"
  },
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.4"
  }
}
