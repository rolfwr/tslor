{
  "linter": {
    "rules": {
      "recommended": false,
      "complexity": {
        "noExcessiveCognitiveComplexity": "error",
        "useMaxParams": {
          "level": "error",
          "options": { "max": 7 }
        }
      },
      "suspicious": {
        "noImportCycles": "error"
      }
    }
  }
}
