{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": [
    "typescript",
    "unicorn",
    "oxc"
  ],
  "categories": {
    "correctness": "error"
  },
  "rules": {
    "no-unused-vars": "error",
    "typescript/no-non-null-assertion": "warn",
    "typescript/no-explicit-any": "warn"
  },
  "env": {
    "builtin": true
  }
}
