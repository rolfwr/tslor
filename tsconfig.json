{
  "compilerOptions": {
    "incremental": true,
    "composite": true,                                
    "target": "ES2022",                               
    "lib": [],
    "module": "ES2022",
    "moduleResolution": "Bundler",
    "rootDir": "./src",
    "paths": {},
    "types": [],
    "typeRoots": [],
    
    // Out directory name chosen because it is by default ignored by vitest
    "outDir": "./.output",                            

    "esModuleInterop": true,                          
    "forceConsistentCasingInFileNames": true,         
    "strict": true,                                   
    "skipLibCheck": true                              
  },
  "exclude": [
    "_*",
    "vitest.config.ts",
    "test-temp"
  ]
}
